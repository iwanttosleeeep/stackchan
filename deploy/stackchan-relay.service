[Unit]
Description=StackChan MCP Relay
After=network-online.target
Wants=network-online.target

[Service]
WorkingDirectory=/opt/stackchan-relay
Environment=STACKCHAN_TOKEN=<TOKEN>
Environment=TTS_VOICE=en-GB-RyanNeural
ExecStart=/opt/stackchan-relay/.venv/bin/uvicorn server:app --host 127.0.0.1 --port 8011
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
